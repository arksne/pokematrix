# PokeMatrix (League17) — Environment Variables
# Copy this to .env for local development.
# On Railway, set these via the dashboard.

# ── Telegram Bot ──────────────────────────────────────────
# REQUIRED for production Telegram Mini App authentication.
# Get this from @BotFather on Telegram:
#   1. Open @BotFather → /newbot → follow prompts
#   2. After creation, BotFather gives you the token like:
#      1234567890:AAHdqTcvCH1vGWJxfSeofSAs0K5PALDsaw
#   3. Set the Mini App URL in BotFather:
#      /mybots → your bot → Bot Settings → Menu Button → Configure
#   4. Set the domain to your Railway URL (e.g., league17-production.up.railway.app)
BOT_TOKEN=

# ── JWT Secret ──────────────────────────────────────────
# Used to sign auth tokens. If not set, a random one is generated
# on restart, which invalidates all active sessions.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# ── Admin ────────────────────────────────────────────────
# Admin password for the /admin panel
# Comma-separated Telegram user IDs that have admin access
ADMIN_PASS=league17admin2026
ADMIN_IDS=1394113078
ADMIN_USERNAMES=nineinchkn5atmythroat

# ── Server ───────────────────────────────────────────────
# Node environment (production/development/test)
# Railway automatically sets this to 'production'
NODE_ENV=development

# Server port (Railway sets this automatically via PORT env)
# PORT=3000

# CORS allowed origin. If empty, allows all origins (required for Telegram Mini App)
# ALLOWED_ORIGIN=

# ── Database ─────────────────────────────────────────────
# Data directory (default: ./data/)
# On Railway, use a volume mount path for persistent data
# DATA_DIR=
RAILWAY_VOLUME_MOUNT_PATH=/data

# ── Logging ──────────────────────────────────────────────
# Log level: fatal, error, warn, info, debug, trace
# LOG_LEVEL=info
# Set to "1" for pretty-printed logs (development)
# PINO_PRETTY=1

# ── Rate Limiting ────────────────────────────────────────
# General rate limit (requests per minute)
# RATE_LIMIT_WINDOW=60
# RATE_LIMIT_MAX=500
# Save endpoint rate limit (requests per minute)
# SAVE_RATE_LIMIT_MAX=30

# ── PokeAPI ──────────────────────────────────────────────
# Base URL for PokeAPI proxy
# POKEAPI_BASE_URL=https://pokeapi.co
