{
    "name": "leaguepm",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
    "render-build": "npm install --include=dev && npm --prefix server install --include=dev && npm --prefix server run build && npx vite build",
        "preview": "vite preview",
        "start": "node server/dist/index.js",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
        "test:vitest": "vitest run",
        "test:browser": "node tests/game-logic-test.cjs && node tests/move-system-test.cjs && node tests/stress-test.cjs",
        "test:e2e": "node e2e/smoke.mjs",
        "test:e2e:headed": "node e2e/smoke.mjs --headed",
        "test:watch": "vitest",
        "test": "bash tests/run-all.sh",
        "gen:images": "node scripts/generate-14-batches.cjs"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "drizzle-kit": "^0.31.10",
        "supertest": "^7.2.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.12",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "playwright": "^1.60.0",
        "socket.io-client": "^4.8.3"
    }
}
