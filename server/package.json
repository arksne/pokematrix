{
  "name": "pokematrix-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate --dialect postgresql --schema src/db/schema.ts --out src/db/migrations",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.42.0",
    "express": "^4.22.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.13.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  }
}
