# PokeMatrix Server — Environment Variables

# Сервер
PORT=3000
NODE_ENV=development

# PostgreSQL (Render: Internal Database URL)
DATABASE_URL=postgres://user:pass@host:5432/pokematrix

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=15m

# Telegram Bot Token (для проверки initData)
BOT_TOKEN=

# Admin
ADMIN_PASS=league17admin2026
ADMIN_IDS=1394113078

# Разрешить dev-логин (без Telegram)
ALLOW_DEV_LOGIN=true

# CORS origins (через запятую)
CORS_ORIGINS=http://localhost:5173

# Логирование
LOG_LEVEL=debug
